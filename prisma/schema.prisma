generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------------
// Core user & client identity
// -------------------------------------------------

model User {
  id                   String                @id @default(cuid())
  clerkUserId          String                @unique
  email                String?               @unique
  firstName            String?
  lastName             String?
  role                 UserRole              @default(CLIENT)
  status               UserStatus            @default(PENDING)
  lastLoginAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  client               Client?               @relation(fields: [clientId], references: [id])
  clientId             String?
  auditLogs            AuditLog[]
  ordersCreated        Order[]               @relation("OrdersCreated")
  ordersApproved       Order[]               @relation("OrdersApproved")
  inventoryAdjustments InventoryAdjustment[]
  inventoryBatches     InventoryBatch[]
  shipmentLabels       ShipmentLabel[]       @relation("LabelsCreated")
  packagePhotos        PackagePhoto[]        @relation("PhotosCaptured")
  notifications        Notification[]
  patientMessages      PatientMessage[]

  @@index([clientId])
}

model Client {
  id                    String                  @id @default(cuid())
  organizationName      String
  // Credentialed medical provider verified against the NPPES NPI Registry.
  npiNumber             String?                 @unique // 10-digit National Provider Identifier
  providerName          String? // Provider/organization name as returned by NPPES
  npiData               Json? // Frozen NPPES registry snapshot at verification time
  // Employer Identification Number (tax ID), optional — formatted as XX-XXXXXXX when known.
  ein                   String?
  contactName           String?
  contactEmail          String?
  contactPhone          String?
  // SMS consent (TCPA / Twilio A2P): captured via the un-prechecked checkbox on
  // the onboarding web form. Texts are only sent when smsOptIn is true.
  smsOptIn              Boolean                 @default(false)
  smsOptInAt            DateTime? // When consent was given (audit trail)
  billingAddress        Json?
  shippingAddress       Json?
  licenseNumber         String?
  licenseExpiresAt      DateTime?
  onboardingStatus      ClientOnboardingStatus  @default(PENDING)
  // Affiliate attribution — which partner org/rep referred this practice.
  // Stamped at onboarding from the /join/<code> referral cookie, or set by an
  // admin. SetNull so partner deletions never break clinics.
  partnerOrg            PartnerOrg?             @relation(fields: [partnerOrgId], references: [id], onDelete: SetNull)
  partnerOrgId          String?
  partnerRep            PartnerRep?             @relation(fields: [partnerRepId], references: [id], onDelete: SetNull)
  partnerRepId          String?
  referralLink          ReferralLink?           @relation(fields: [referralLinkId], references: [id], onDelete: SetNull)
  referralLinkId        String?
  // Clinic-to-clinic referral program: this clinic's shareable code
  // (/refer/<code>, generated lazily) and which clinic referred THEM. The
  // referrer earns store credit on every captured purchase this clinic makes
  // (lib/referrals/credit.ts). Independent of partner attribution.
  referralCode          String?                 @unique
  referredBy            Client?                 @relation("ClinicReferrals", fields: [referredByClientId], references: [id], onDelete: SetNull)
  referredByClientId    String?
  referredClinics       Client[]                @relation("ClinicReferrals")
  // Net-terms billing. When set, the client may check out "bill to account"
  // (order is invoiced on these terms instead of paying by card). NULL = card
  // only. creditLimit (dollars) caps open AR + the new order; NULL = no cap.
  paymentTermsDays      Int?
  creditLimit           Decimal?                @db.Decimal(12, 2)
  // Stripe Customer for this B2B account. Saved cards are shared across the
  // client's users. Stripe never holds our product catalog (Model A).
  stripeCustomerId      String?                 @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  users                 User[]
  orders                Order[]
  documents             ClientDocument[]
  customPricing         ClientPricing[]
  paymentMethods        PaymentMethod[]
  patients              Patient[]
  shipmentLabels        ShipmentLabel[]
  packagePhotos         PackagePhoto[]
  notifications         Notification[]
  returnRequests        ReturnRequest[]
  storefront            Storefront?
  invoices              Invoice[]
  patientMessages       PatientMessage[]
  partnerTransactions   PartnerTransaction[]
  partnerClinicMeta     PartnerClinicMeta[]
  partnerClinicActivity PartnerClinicActivity[]
  creditEntries         ClientCreditEntry[]     @relation("CreditOwner")
  creditEntriesAsSource ClientCreditEntry[]     @relation("CreditSource")

  @@index([partnerOrgId])
  @@index([partnerRepId])
  @@index([referredByClientId])
}

// -------------------------------------------------
// Clinic referral store credit. A clinic that refers another clinic earns
// CLINIC_REFERRAL_RATE_BPS (default 5%) of every captured purchase the
// referred clinic makes, as store credit redeemable at checkout.
//
// Signed integer-cents ledger: EARNED/ADJUSTMENT rows are positive,
// REVERSED (refund clawback) and REDEEMED rows are negative. Balance is the
// plain SUM. `reference` is unique for idempotency ("earn:order:<id>",
// "redeem:order:<id>", "unredeem:order:<id>"; reversal rows carry the
// cumulative position). SetNull relations keep history when sources go away.
// -------------------------------------------------

model ClientCreditEntry {
  id             String           @id @default(cuid())
  client         Client           @relation("CreditOwner", fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String
  amountCents    Int // signed: positive = credit in, negative = credit out
  kind           ClientCreditKind
  // The referred clinic whose purchase generated this entry (EARNED/REVERSED).
  sourceClient   Client?          @relation("CreditSource", fields: [sourceClientId], references: [id], onDelete: SetNull)
  sourceClientId String?
  order          Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId        String?
  reference      String?          @unique
  note           String?
  createdBy      String? // Clerk id for manual ADJUSTMENT rows
  createdAt      DateTime         @default(now())

  @@index([clientId, createdAt])
  @@index([orderId])
}

enum ClientCreditKind {
  EARNED // 5% of a referred clinic's captured purchase
  REVERSED // proportional clawback when that purchase is refunded
  REDEEMED // credit applied to this clinic's own order at checkout
  UNREDEEMED // credit restored when an order that used credit is refunded
  ADJUSTMENT // manual admin grant/correction
}

// Saved ship-to recipient for a practice ("ship to patient" at checkout).
// Minimal PII only — name + address + optional contact. No health data.
model Patient {
  id        String           @id @default(cuid())
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  firstName String
  lastName  String
  address   Json // { address1, address2?, city, state, zip, country? }
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  orders    Order[]
  messages  PatientMessage[]

  @@index([clientId])
}

// Two-way chat between the clinic (CLIENT users) and PeptSci staff (admins),
// threaded per patient. Each side has its own read flag: the sender's side is
// marked read at creation, the other side flips on fetch. senderName is frozen
// at send time so history survives user deletion (senderId nulls out).
model PatientMessage {
  id           String                   @id @default(cuid())
  patient      Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId    String
  // Denormalized from Patient for fast clinic-ownership checks and unread rollups.
  client       Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  sender       User?                    @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderId     String?
  senderName   String
  senderRole   PatientMessageSenderRole
  body         String
  readByClinic Boolean                  @default(false)
  readByAdmin  Boolean                  @default(false)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([patientId, createdAt])
  @@index([clientId, senderRole, readByClinic])
  @@index([patientId, senderRole, readByAdmin])
}

// Saved card (or other payment method) for a client's Stripe Customer.
// Card PAN never touches our DB — only Stripe's tokenized id + display fields.
model PaymentMethod {
  id                    String    @id @default(cuid())
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String
  stripePaymentMethodId String    @unique
  cardBrand             String?
  cardLast4             String?
  expiryMonth           Int?
  expiryYear            Int?
  cardholderName        String?
  billingZip            String?
  isDefault             Boolean   @default(false)
  isActive              Boolean   @default(true)
  lastUsedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  orders                Order[]

  @@index([clientId])
}

// Stripe webhook event log used for idempotency + audit (DLQ on failure).
// One row per Stripe event id; processing is skipped if a row already exists.
model WebhookEvent {
  id           String             @id @default(cuid())
  source       String             @default("stripe")
  eventId      String             @unique
  eventType    String
  status       WebhookEventStatus @default(RECEIVED)
  errorMessage String?
  payload      Json?
  processingMs Int?
  retryCount   Int                @default(0)
  processedAt  DateTime?
  createdAt    DateTime           @default(now())

  @@index([eventType])
  @@index([status])
}

enum WebhookEventStatus {
  RECEIVED
  SUCCESS
  ERROR
}

// Custom pricing per client - overrides standard SRP
model ClientPricing {
  id              String         @id @default(cuid())
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId       String
  customPrice     Decimal        @db.Decimal(12, 2) // The special price for this client
  discountPercent Decimal?       @db.Decimal(5, 2) // Optional: track as % off SRP
  notes           String? // Reason for custom pricing
  validFrom       DateTime? // Optional: pricing effective date
  validUntil      DateTime? // Optional: pricing expiration
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String? // Admin who set this price

  @@unique([clientId, variantId]) // One custom price per client per variant
  @@index([clientId])
  @@index([variantId])
}

// Compliance document for a practice (license / DEA / insurance / resale
// cert). File bytes live in blob storage (fileUrl) or inline base64 — same
// dual-backend pattern as PackagePhoto/ShipmentLabel (lib/storage.ts). Files
// are only ever served through auth-gated proxy routes.
model ClientDocument {
  id          String               @id @default(cuid())
  client      Client               @relation(fields: [clientId], references: [id])
  clientId    String
  type        ClientDocumentType
  label       String? // free-text label, mainly for OTHER
  fileUrl     String? // blob URL when the blob backend is used
  fileBase64  String? // inline fallback when no blob backend
  contentType String?
  fileName    String?
  fileSize    Int?
  status      ClientDocumentStatus @default(PENDING_REVIEW)
  reviewNotes String? // admin note shown to the client (esp. on rejection)
  reviewedBy  String?
  reviewedAt  DateTime?
  expiresAt   DateTime? // document expiration (license/DEA renewals)
  uploadedBy  String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @default(now()) @updatedAt

  @@index([clientId])
  @@index([status])
}

enum ClientDocumentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

// -------------------------------------------------
// White-Label Storefronts
// -------------------------------------------------

model Storefront {
  id             String              @id @default(cuid())
  client         Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String              @unique
  slug           String              @unique // Subdomain slug, e.g. "drclinic" -> drclinic.peptsci.com
  name           String
  brandingConfig Json? // BrandingConfig: logo, colors, fonts, hero, footer, about, contact, socials
  status         StorefrontStatus    @default(DRAFT)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  products       StorefrontProduct[]
  endCustomers   EndCustomer[]
  retailOrders   RetailOrder[]

  @@index([slug])
}

model StorefrontProduct {
  id                 String                 @id @default(cuid())
  storefront         Storefront             @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  storefrontId       String
  variant            ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId          String
  isEnabled          Boolean                @default(true)
  isFeatured         Boolean                @default(false)
  displayOrder       Int                    @default(0)
  displayName        String? // Override product name for this storefront
  displayDescription String? // Override description for this storefront
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  retailPrice        StorefrontRetailPrice?
  retailOrderItems   RetailOrderItem[]

  @@unique([storefrontId, variantId])
  @@index([storefrontId])
  @@index([variantId])
}

model StorefrontRetailPrice {
  id                  String            @id @default(cuid())
  storefrontProduct   StorefrontProduct @relation(fields: [storefrontProductId], references: [id], onDelete: Cascade)
  storefrontProductId String            @unique
  retailPrice         Decimal           @db.Decimal(12, 2)
  compareAtPrice      Decimal?          @db.Decimal(12, 2) // Optional strikethrough price
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model EndCustomer {
  id              String        @id @default(cuid())
  storefront      Storefront    @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  storefrontId    String
  email           String
  firstName       String?
  lastName        String?
  phone           String?
  passwordHash    String? // bcrypt hash; null for guest customers
  isGuest         Boolean       @default(false)
  shippingAddress Json?
  billingAddress  Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  retailOrders    RetailOrder[]

  @@unique([storefrontId, email])
  @@index([storefrontId])
  @@index([email])
}

model RetailOrder {
  id                    String            @id @default(cuid())
  orderNumber           String            @unique // e.g. "SF-drclinic-00001"
  storefront            Storefront        @relation(fields: [storefrontId], references: [id])
  storefrontId          String
  endCustomer           EndCustomer?      @relation(fields: [endCustomerId], references: [id])
  endCustomerId         String?
  guestEmail            String? // For guest checkout without EndCustomer account
  status                RetailOrderStatus @default(PENDING)
  // Retail card payment (Stripe PI with metadata.retailOrderId).
  paymentStatus         PaymentStatus     @default(PENDING)
  stripePaymentIntentId String?           @unique
  paidAt                DateTime?
  subtotal              Decimal           @db.Decimal(12, 2)
  taxTotal              Decimal           @default(0) @db.Decimal(12, 2)
  shippingTotal         Decimal           @default(0) @db.Decimal(12, 2)
  total                 Decimal           @db.Decimal(12, 2)
  currency              String            @default("USD")
  shippingAddress       Json?
  billingAddress        Json?
  notes                 String?
  peptsciOrder          Order?            @relation(fields: [peptsciOrderId], references: [id])
  peptsciOrderId        String?           @unique // Link to auto-generated PeptSci order
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  items                 RetailOrderItem[]

  @@index([storefrontId])
  @@index([endCustomerId])
  @@index([peptsciOrderId])
  @@index([storefrontId, createdAt])
}

model RetailOrderItem {
  id                  String            @id @default(cuid())
  retailOrder         RetailOrder       @relation(fields: [retailOrderId], references: [id], onDelete: Cascade)
  retailOrderId       String
  storefrontProduct   StorefrontProduct @relation(fields: [storefrontProductId], references: [id])
  storefrontProductId String
  quantity            Int
  unitRetailPrice     Decimal           @db.Decimal(12, 2) // Price end customer paid
  totalPrice          Decimal           @db.Decimal(12, 2)
  createdAt           DateTime          @default(now())
}

// -------------------------------------------------
// Catalog & Inventory
// -------------------------------------------------

model Product {
  id                        String           @id @default(cuid())
  sku                       String?          @unique
  airtableId                String?          @unique // Link to Airtable record for content sync
  name                      String
  description               String?
  category                  String?
  status                    ProductStatus    @default(ACTIVE)
  // Scientific / reference data (per compound, populated by catalog CSV import)
  casNumber                 String?
  molecularFormula          String?
  molecularWeight           Float? // g/mol
  pubchemCid                String?
  peptideLength             Int? // number of amino acid residues
  aka                       String? // synonyms / "also known as"
  monoisotopicMass          Float?
  complexity                Float? // PubChem complexity score
  xlogp                     Float?
  hydrogenBondDonorCount    Int?
  hydrogenBondAcceptorCount Int?
  rotatableBondCount        Int?
  heavyAtomCount            Int?
  intendedUse               String?
  safetySummary             String? // PubChem Laboratory Chemical Safety Summary (LCSS)
  // Editorial monograph content shown on the product detail page. Structured
  // JSON: { overview: string[], mechanismOfAction: string[],
  // observations: { title, detail }[], references: { label, url? }[], disclaimer? }
  monograph                 Json?
  purity                    String? // e.g. "99%"; rendered on the PDP specifications strip
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  variants                  ProductVariant[]
  media                     ProductMedia[]
}

model ProductVariant {
  id                 String                 @id @default(cuid())
  product            Product                @relation(fields: [productId], references: [id])
  productId          String
  airtableId         String?                @unique // Link to Airtable variant record
  sku                String?                @unique // Variant-level SKU for ordering
  dose               String?
  unitSize           String?
  unitCost           Decimal                @db.Decimal(12, 2)
  srp                Decimal                @db.Decimal(12, 2)
  // How we buy this from the manufacturer (purchasing terms)
  supplierName       String? // Manufacturer / supplier name
  supplierSku        String? // Supplier's catalog # / SKU for reorder
  inventoryOnHand    Int                    @default(0)
  // Units committed to open orders but not yet physically shipped. Availability
  // for new orders is (inventoryOnHand - inventoryReserved). Maintained by the
  // reservation service (lib/inventory/reservations.ts); never edited directly.
  inventoryReserved  Int                    @default(0)
  reorderLevel       Int                    @default(0)
  status             ProductStatus          @default(ACTIVE)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  orderItems         OrderItem[]
  inventoryLogs      InventoryAdjustment[]
  clientPricing      ClientPricing[]
  storefrontProducts StorefrontProduct[]
  batches            InventoryBatch[]
  returnItems        ReturnItem[]
  reservations       InventoryReservation[]
  partnerOrgPricing  PartnerOrgPricing[]
  coas               ProductCoa[]

  @@index([status])
  @@index([productId])
}

// -------------------------------------------------
// Certificate of Analysis (supplier COA) — attached per variant
// -------------------------------------------------

// A supplier Certificate of Analysis for a specific product variant. Admins
// upload the original supplier document (JPG/PDF, stored via lib/storage in the
// same dual blob/base64 fashion as ClientDocument) and enter the structured
// results by hand. Those structured values drive the styled COA page rendered
// on the storefront; the uploaded file is retained as the source of record.
// A variant may have several COAs (one per production lot / batch).
model ProductCoa {
  id        String         @id @default(cuid())
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId String

  // Source document (dual storage backends — see lib/storage.ts)
  fileUrl     String? // Vercel Blob URL (driver 'blob')
  fileBase64  String? // inline base64 payload (driver 'inline')
  contentType String? // e.g. image/jpeg, application/pdf
  fileName    String?

  // Identity / header
  compoundName String // e.g. "GHK-Cu"
  doseLabel    String? // e.g. "50 mg"
  casNumber    String?
  appearance   String? // e.g. "Lyophilized powder"
  batchNumber  String?
  taskNumber   String? // supplier task / report number
  reportCode   String?
  issuingLab   String? // lab that issued the certificate
  signedBy     String?

  // Parties
  manufacturer   String?
  testingLab     String?
  clientOfRecord String?
  distributor    String?

  // Chain-of-custody dates
  orderedOn  DateTime?
  receivedOn DateTime?
  analyzedOn DateTime?

  // Purity (% w/w)
  purityPercent   Float? // measured purity, e.g. 99.669
  puritySpecMin   Float? @default(98) // spec floor (>= this %)
  purityRejectMax Float? @default(2) // total-impurity allowance (%)

  // Assay content (mg)
  assayMeasuredMg   Float? // measured content, e.g. 50.69
  assayLabelClaimMg Float? // label claim, e.g. 50

  // Identity confirmation
  identitySpec   String?
  identityResult String?

  notes     String? // internal/qualification notes
  published Boolean  @default(true) // visible on the storefront when true
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variantId])
  @@index([published])
}

// -------------------------------------------------
// Inventory Batches (intake + BUD + auto batch# / barcode / labels)
// -------------------------------------------------

// A single recorded inbound inventory receipt. The batch number and Code128
// barcode payload are derived from product name + dose + BUD at creation time
// (see lib/batch-number.ts) and are immutable thereafter. Receiving a batch
// increments ProductVariant.inventoryOnHand and writes an InventoryAdjustment.
model InventoryBatch {
  id             String                @id @default(cuid())
  batchNumber    String                @unique // e.g. "TES10-072027" — also the Code128 barcode payload
  variant        ProductVariant        @relation(fields: [variantId], references: [id])
  variantId      String
  // Label snapshots — frozen at intake so later catalog edits never change a printed batch.
  productName    String // e.g. "Tesamorelin"
  dose           String // e.g. "10mg" (label dose-box top line)
  vialSize       String? // e.g. "3mL"
  purity         String                @default("99%HPLC") // label dose-box bottom line
  bud            DateTime // Beyond-Use Date
  receivedOn     DateTime              @default(now())
  qtyReceived    Int
  qtyDamaged     Int                   @default(0)
  qtyOnHand      Int // decremented as labels/orders consume
  yearColor      String? // optional hex accent for BUD day + batch text
  notes          String?
  status         BatchStatus           @default(RECEIVED)
  receivedBy     User?                 @relation(fields: [receivedById], references: [id])
  receivedById   String?
  receivedByName String? // snapshot of operator name/email
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  events         InventoryBatchEvent[]

  @@index([variantId])
  @@index([status])
  @@index([bud])
  @@index([createdAt])
}

// Immutable audit trail for a batch (receipt, manual adjustment, label print, void).
model InventoryBatchEvent {
  id          String         @id @default(cuid())
  batch       InventoryBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId     String
  type        BatchEventType
  delta       Int? // qty change (negative for consumption), when applicable
  note        String?
  performedBy String? // operator name/email snapshot
  createdAt   DateTime       @default(now())

  @@index([batchId])
}

enum BatchStatus {
  RECEIVED
  DEPLETED
  VOIDED
}

enum BatchEventType {
  RECEIVED
  ADJUSTED
  LABELS_PRINTED
  ALLOCATED
  VOIDED
}

model ProductMedia {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

model InventoryAdjustment {
  id            String                    @id @default(cuid())
  variant       ProductVariant            @relation(fields: [variantId], references: [id])
  variantId     String
  delta         Int
  reason        InventoryAdjustmentReason
  note          String?
  order         Order?                    @relation(fields: [orderId], references: [id])
  orderId       String?
  createdBy     User?                     @relation(fields: [createdById], references: [id])
  createdById   String?
  // Display fallback when the actor has no User row (e.g. Clerk id only)
  createdByName String?
  createdAt     DateTime                  @default(now())

  @@index([variantId])
  @@index([orderId])
  @@index([createdAt])
}

// -------------------------------------------------
// Ordering & Payments
// -------------------------------------------------

model Order {
  id                    String                 @id @default(cuid())
  orderNumber           Int                    @default(autoincrement())
  client                Client                 @relation(fields: [clientId], references: [id])
  clientId              String
  source                OrderSource            @default(DIRECT)
  status                OrderStatus            @default(DRAFT)
  paymentStatus         PaymentStatus          @default(PENDING)
  subtotal              Decimal                @db.Decimal(12, 2)
  taxTotal              Decimal                @default(0) @db.Decimal(12, 2)
  shippingTotal         Decimal                @default(0) @db.Decimal(12, 2)
  total                 Decimal                @db.Decimal(12, 2)
  currency              String                 @default("USD")
  notes                 String?
  internalNotes         String?
  shippingAddress       Json?
  // Where the order ships and how fast (priced server-side; see lib/checkout-core.ts).
  shipTo                ShipTo                 @default(PRACTICE)
  shipSpeed             ShipSpeed              @default(TWO_DAY)
  patient               Patient?               @relation(fields: [patientId], references: [id])
  patientId             String?
  // Carrier tracking — set when a FedEx label is created (see lib/fedex.ts).
  carrier               String?
  trackingNumber        String?
  trackingUrl           String?
  shippingStatus        String? // e.g. LABEL_CREATED, IN_TRANSIT, DELIVERED
  shippedAt             DateTime?
  stripePaymentIntentId String?                @unique
  stripeChargeId        String?
  paymentMethod         PaymentMethod?         @relation(fields: [paymentMethodId], references: [id])
  paymentMethodId       String?
  paymentFailureReason  String?
  paidAt                DateTime?
  // Cumulative refunds issued against this order (Stripe or manual). When
  // refundedTotal >= total the order's paymentStatus becomes REFUNDED.
  refundedTotal         Decimal                @default(0) @db.Decimal(12, 2)
  refundedAt            DateTime?
  // Referral store credit applied at checkout (dollars). The card is charged
  // `total`, which is already net of this credit; the REDEEMED ledger row is
  // written at capture. Full-credit orders (total 0) skip Stripe entirely.
  creditApplied         Decimal                @default(0) @db.Decimal(12, 2)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  submittedAt           DateTime?
  approvedAt            DateTime?
  fulfilledAt           DateTime?
  createdBy             User                   @relation("OrdersCreated", fields: [createdById], references: [id])
  createdById           String
  approvedBy            User?                  @relation("OrdersApproved", fields: [approvedById], references: [id])
  approvedById          String?
  items                 OrderItem[]
  documents             OrderDocument[]
  inventoryAdjustments  InventoryAdjustment[]
  auditLogs             AuditLog[]
  shipmentLabels        ShipmentLabel[]
  packagePhotos         PackagePhoto[]
  retailOrder           RetailOrder?
  returnRequests        ReturnRequest[]
  reservations          InventoryReservation[]
  fulfillment           OrderFulfillment?
  invoiceLineItems      InvoiceLineItem[]
  creditEntries         ClientCreditEntry[]

  @@index([clientId])
  @@index([stripePaymentIntentId])
  @@index([trackingNumber])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([stripeChargeId])
  @@index([clientId, status, createdAt])
}

model OrderItem {
  id             String                 @id @default(cuid())
  order          Order                  @relation(fields: [orderId], references: [id])
  orderId        String
  variant        ProductVariant         @relation(fields: [variantId], references: [id])
  variantId      String
  quantity       Int
  unitPrice      Decimal                @db.Decimal(12, 2)
  discountAmount Decimal                @default(0) @db.Decimal(12, 2)
  totalPrice     Decimal                @db.Decimal(12, 2)
  createdAt      DateTime               @default(now())
  returnItems    ReturnItem[]
  reservations   InventoryReservation[]

  @@index([orderId])
  @@index([variantId])
}

// -------------------------------------------------
// Billing & invoicing (B2B accounts receivable). An Invoice consolidates one or
// more orders (or manual lines) for a Client over a billing period, with Net
// payment terms, partial payments, discounts/surcharges, balance-forward, and
// aging. Pure totals/aging/status logic lives in lib/invoicing/core.ts (adapted
// from eonpro/logos-rx-invoicing). The heavyweight double-entry GL, fiscal
// periods, and Plaid reconciliation from that repo are intentionally omitted.
// -------------------------------------------------

model Invoice {
  id               String              @id @default(cuid())
  invoiceNumber    Int                 @unique @default(autoincrement())
  client           Client              @relation(fields: [clientId], references: [id])
  clientId         String
  status           InvoiceStatus       @default(DRAFT)
  periodStart      DateTime?
  periodEnd        DateTime?
  issueDate        DateTime            @default(now())
  paymentTermsDays Int                 @default(30)
  dueDate          DateTime?
  // Unpaid balance carried in from a prior invoice (Decimal dollars).
  balanceForward   Decimal             @default(0) @db.Decimal(12, 2)
  currency         String              @default("USD")
  notes            String?
  createdById      String?
  voidedAt         DateTime?
  paidAt           DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  lineItems        InvoiceLineItem[]
  payments         InvoicePayment[]
  adjustments      InvoiceAdjustment[]

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([clientId, status])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  order       Order?   @relation(fields: [orderId], references: [id])
  // Unique: an order can be billed on at most ONE line item. Voiding an invoice
  // sets orderId NULL on its lines (see voidInvoice), so voided invoices don't
  // hold the slot and the order becomes billable again. NULLs are distinct, so
  // manual (order-less) lines are unlimited. This is the durable double-billing
  // guard behind the transactional check in createInvoice.
  orderId     String?  @unique
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

model InvoiceAdjustment {
  id        String         @id @default(cuid())
  invoice   Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  kind      AdjustmentKind
  // Exactly one of amount (FIXED dollars) / percent (PERCENT of subtotal) is set.
  // Negative = discount/credit, positive = surcharge/fee.
  amount    Decimal?       @db.Decimal(12, 2)
  percent   Decimal?       @db.Decimal(6, 3)
  reason    String         @default("")
  createdBy String?
  createdAt DateTime       @default(now())

  @@index([invoiceId])
}

model InvoicePayment {
  id                    String   @id @default(cuid())
  invoice               Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId             String
  amount                Decimal  @db.Decimal(12, 2)
  method                String? // wire | ach | check | card | stripe | other
  reference             String?
  stripePaymentIntentId String?  @unique
  notes                 String?
  paidAt                DateTime @default(now())
  createdAt             DateTime @default(now())

  @@index([invoiceId])
}

model OrderDocument {
  id         String            @id @default(cuid())
  order      Order             @relation(fields: [orderId], references: [id])
  orderId    String
  type       OrderDocumentType
  fileUrl    String
  uploadedBy String?
  createdAt  DateTime          @default(now())
}

// -------------------------------------------------
// Shipping: FedEx labels + outgoing-package proof photos
// (ported from eonpro/logosrx.eonpro.io, mapped to the B2B Client/Order domain)
// -------------------------------------------------

// A FedEx shipping label created for an order. The label PDF/ZPL/PNG is stored
// via lib/storage.ts (blob URL) with a base64 fallback in-row. Creating a label
// writes the tracking number/URL back onto the linked Order.
model ShipmentLabel {
  id                 String              @id @default(cuid())
  order              Order?              @relation(fields: [orderId], references: [id])
  orderId            String?
  client             Client?             @relation(fields: [clientId], references: [id])
  clientId           String?
  createdBy          User?               @relation("LabelsCreated", fields: [createdById], references: [id])
  createdById        String?
  carrier            String              @default("FEDEX")
  trackingNumber     String
  shipmentId         String? // FedEx master tracking id
  serviceType        String // FEDEX_GROUND, STANDARD_OVERNIGHT, etc.
  originAddress      Json // snapshot at label creation
  destinationAddress Json
  weightLbs          Float               @default(1.0)
  length             Float?
  width              Float?
  height             Float?
  labelFormat        String              @default("PDF") // PDF | ZPLII | PNG
  labelBlobUrl       String? // storage URL when blob backend is used
  labelPdfBase64     String? // inline fallback when no blob backend
  status             ShipmentLabelStatus @default(CREATED)
  voidedAt           DateTime?
  voidedById         String?
  createdAt          DateTime            @default(now())

  @@index([orderId])
  @@index([clientId])
  @@index([trackingNumber])
}

enum ShipmentLabelStatus {
  CREATED
  VOIDED
}

// Proof-of-shipment photo captured by a warehouse rep for an outgoing package.
// Matched to an Order by the scanned/typed order number; the owning client can
// view it on their order detail page.
model PackagePhoto {
  id             String    @id @default(cuid())
  order          Order?    @relation(fields: [orderId], references: [id])
  orderId        String?
  client         Client?   @relation(fields: [clientId], references: [id])
  clientId       String?
  // The identifier the rep scanned/typed (PeptSci Order.orderNumber as text).
  orderRef       String
  trackingNumber String?
  trackingSource String? // order | fedex_label | manual
  capturedBy     User?     @relation("PhotosCaptured", fields: [capturedById], references: [id])
  capturedById   String?
  blobUrl        String? // storage URL when blob backend is used
  imageBase64    String? // inline fallback when no blob backend
  contentType    String    @default("image/jpeg")
  fileSize       Int?
  matched        Boolean   @default(false)
  matchedAt      DateTime?
  notes          String?
  createdAt      DateTime  @default(now())

  @@index([orderId])
  @@index([clientId])
  @@index([orderRef])
  @@index([createdAt])
}

// -------------------------------------------------
// Analytics: Sales records (replaces Google Sheets "Sales" tab)
// -------------------------------------------------

// A flat per-order sales record powering dashboard / customers / P&L / search.
// Populated by three writers, each with its own dedup key so re-runs are safe:
//   - Platform orders  -> upsert by `orderId` (real COGS from ProductVariant)
//   - Stripe backfill   -> upsert by `stripePaymentIntentId` (PIs with no order)
//   - CSV upload        -> upsert by `externalId` when provided, else insert
model SalesRecord {
  id                    String    @id @default(cuid())
  date                  DateTime?
  orderRef              String    @default("") // display order id, e.g. "P-0604-001" or "#1234"
  customerName          String    @default("")
  customerEmail         String    @default("")
  customerPhone         String    @default("")
  address               String    @default("")
  city                  String    @default("")
  state                 String    @default("")
  zip                   String    @default("")
  trackingNumber        String    @default("")
  invoicePaid           Boolean   @default(false)
  paidAmount            Decimal   @default(0) @db.Decimal(12, 2)
  vials                 Int       @default(0)
  amountPerVial         Decimal   @default(0) @db.Decimal(12, 2)
  product               String    @default("")
  notes                 String    @default("")
  unitCost              Decimal   @default(0) @db.Decimal(12, 2)
  cogs                  Decimal   @default(0) @db.Decimal(12, 2)
  source                String    @default("manual") // manual | csv | stripe | order
  orderId               String?   @unique // links to Order.id when source = order
  stripePaymentIntentId String?   @unique // links to Stripe PI when source = stripe
  externalId            String?   @unique // CSV-provided stable id for re-import upserts
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([date])
  @@index([customerEmail])
}

// -------------------------------------------------
// Analytics: Competitor price comparison (replaces "Competitor Comparison" tab)
// -------------------------------------------------

model CompetitorPrice {
  id             String   @id @default(cuid())
  competitorName String
  productName    String
  dose           String   @default("")
  theirPrice     Decimal  @db.Decimal(12, 2)
  ourSrp         Decimal  @db.Decimal(12, 2)
  diff           Decimal? @db.Decimal(12, 2) // ourSrp - theirPrice; computed on write when omitted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([competitorName, productName, dose])
  @@index([productName])
}

// -------------------------------------------------
// Purchasing: Distributor orders + expenses (replaces "Orders /Expenses" tab)
// -------------------------------------------------

model DistributorOrder {
  id             String                 @id @default(cuid())
  externalId     String?                @unique // e.g. "DO-20260604-001" for re-import upserts
  orderDate      DateTime?
  vendor         String                 @default("Distributor")
  subtotal       Decimal                @default(0) @db.Decimal(12, 2)
  shipping       Decimal                @default(0) @db.Decimal(12, 2)
  paypalFee      Decimal                @default(0) @db.Decimal(12, 2)
  total          Decimal                @default(0) @db.Decimal(12, 2)
  status         String                 @default("delivered") // pending | shipped | delivered
  trackingNumber String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  lines          DistributorOrderLine[]

  @@index([orderDate])
}

model DistributorOrderLine {
  id          String           @id @default(cuid())
  order       DistributorOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  productName String
  dose        String           @default("")
  quantity    Int              @default(0)
  unitCost    Decimal          @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal          @default(0) @db.Decimal(12, 2)
  createdAt   DateTime         @default(now())

  @@index([orderId])
}

// -------------------------------------------------
// Audit & Notifications
// -------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  entity    String
  entityId  String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  order     Order?   @relation(fields: [orderId], references: [id])
  orderId   String?

  @@index([userId])
  @@index([orderId])
  @@index([entity, entityId])
}

// In-app notification for an admin user (ported from eonpro/eonpro, trimmed to
// the B2B commerce/fulfillment domain). Created by transactional triggers and
// the Vercel Cron jobs. Deduplicated by (userId, sourceType, sourceId) so a
// repeated cron run or webhook redelivery never double-notifies.
model Notification {
  id         String               @id @default(cuid())
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  client     Client?              @relation(fields: [clientId], references: [id])
  clientId   String?
  category   NotificationCategory
  priority   NotificationPriority @default(NORMAL)
  title      String
  message    String
  actionUrl  String? // deep-link to the relevant admin page
  metadata   Json? // extra context (orderId, variantId, batchId, …)
  isRead     Boolean              @default(false)
  readAt     DateTime?
  isArchived Boolean              @default(false)
  archivedAt DateTime?
  // Source tracking for dedup + audit: e.g. ('cron:fedex-tracking', orderId).
  sourceType String?
  sourceId   String?

  // Durable dedup: racing cron runs / webhook redeliveries can't double-notify.
  // Rows with NULL sourceType/sourceId are exempt (Postgres treats NULLs as
  // distinct), so non-dedupable notifications are unaffected.
  @@unique([userId, sourceType, sourceId])
  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isArchived])
  @@index([sourceType, sourceId])
}

// -------------------------------------------------
// Returns / RMA (ported from eonpro/fulfillment-platform, mapped to the B2B
// Order/Variant/Inventory domain). A return is opened against an Order; received
// GOOD items can be restocked, which bumps ProductVariant.inventoryOnHand and
// writes an InventoryAdjustment (reason RETURN).
// -------------------------------------------------

model ReturnRequest {
  id            String       @id @default(cuid())
  rmaNumber     String       @unique // e.g. "RMA-20260628-001"
  order         Order        @relation(fields: [orderId], references: [id])
  orderId       String
  client        Client?      @relation(fields: [clientId], references: [id])
  clientId      String?
  status        ReturnStatus @default(REQUESTED)
  reason        String?
  notes         String?
  refundAmount  Decimal?     @db.Decimal(12, 2)
  // User.id snapshot of who opened the RMA (no relation to keep churn low).
  requestedById String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  approvedAt    DateTime?
  receivedAt    DateTime?
  closedAt      DateTime?
  items         ReturnItem[]

  @@index([orderId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model ReturnItem {
  id              String              @id @default(cuid())
  returnRequest   ReturnRequest       @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  returnRequestId String
  orderItem       OrderItem?          @relation(fields: [orderItemId], references: [id])
  orderItemId     String?
  variant         ProductVariant?     @relation(fields: [variantId], references: [id])
  variantId       String?
  productName     String // snapshot for display even if variant later changes
  quantity        Int
  condition       ReturnItemCondition @default(GOOD)
  restocked       Boolean             @default(false)
  notes           String?
  createdAt       DateTime            @default(now())

  @@index([returnRequestId])
  @@index([variantId])
}

// -------------------------------------------------
// Warehouse pick/pack fulfillment state for an order (1:1). Tracks the pick →
// pack workflow distinct from Order.status/shippingStatus. verifiedItems is a
// snapshot of the operator's pack count per line ([{variantId, productName,
// expected, packed}]). Physical stock consumption still happens via the batch
// label-consume path; this records who picked/packed and when.
// -------------------------------------------------

model OrderFulfillment {
  id            String           @id @default(cuid())
  order         Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String           @unique
  stage         FulfillmentStage @default(NOT_STARTED)
  pickedAt      DateTime?
  pickedById    String?
  packedAt      DateTime?
  packedById    String?
  verifiedItems Json?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([stage])
}

// -------------------------------------------------
// Inventory reservations (order-linked stock commitments). Reserving an order's
// lines increments ProductVariant.inventoryReserved without touching on-hand, so
// availability for new orders is (inventoryOnHand - inventoryReserved). Lifecycle:
// reserve at order submit/capture, release on cancel/refund, consume at
// fulfillment (reserved is freed; on-hand is decremented by the batch consume).
// -------------------------------------------------

model InventoryReservation {
  id          String            @id @default(cuid())
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  variant     ProductVariant    @relation(fields: [variantId], references: [id])
  variantId   String
  orderItem   OrderItem?        @relation(fields: [orderItemId], references: [id])
  orderItemId String?
  quantity    Int
  status      ReservationStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  releasedAt  DateTime?
  consumedAt  DateTime?

  @@unique([orderId, variantId])
  @@index([variantId])
  @@index([status])
}

// -------------------------------------------------
// Affiliate partner program (ported from eonpro/logosrx-website partner
// portal). Sales organizations (PartnerOrg) and their reps earn commission on
// attributed clinics' (Client) captured orders. All partner money columns are
// INTEGER CENTS and all rates are INTEGER BASIS POINTS (100 bps = 1%) so
// splits are exact — see lib/partners/commission.ts.
// -------------------------------------------------

model PartnerOrg {
  id                String                   @id @default(cuid())
  // Clerk account of the org owner; linked when the invited owner signs up.
  clerkUserId       String?                  @unique
  name              String
  contactName       String?
  contactEmail      String                   @unique
  contactPhone      String?
  website           String?
  notes             String?
  status            PartnerStatus            @default(PENDING)
  // COMMISSION: org earns commissionRateBps of attributed revenue.
  // MARGIN: org prices clinics above per-variant floors and earns the spread.
  compensationModel PartnerCompensationModel @default(COMMISSION)
  commissionRateBps Int                      @default(0)
  msaSignedAt       DateTime?
  approvedAt        DateTime?
  approvedBy        String? // Clerk id of the approving admin
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  reps              PartnerRep[]
  members           PartnerOrgMember[]
  referralLinks     ReferralLink[]
  clients           Client[]
  transactions      PartnerTransaction[]
  commissionEntries CommissionEntry[]
  payouts           PartnerPayout[]
  pricing           PartnerOrgPricing[]
  agreements        PartnerAgreement[]
  clinicMeta        PartnerClinicMeta[]
  clinicActivity    PartnerClinicActivity[]
  goals             PartnerGoal[]
  quotes            PartnerQuote[]
  apiKeys           PartnerApiKey[]
  webhooks          PartnerWebhook[]

  @@index([status])
}

model PartnerRep {
  id                String                  @id @default(cuid())
  org               PartnerOrg              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId             String
  clerkUserId       String?                 @unique
  name              String
  email             String
  phone             String?
  status            PartnerStatus           @default(PENDING)
  // Rep's carve-out rate, taken OUT of the org's commission (≤ org rate for
  // COMMISSION orgs; share of margin for MARGIN orgs).
  commissionRateBps Int                     @default(0)
  msaSignedAt       DateTime?
  invitedAt         DateTime                @default(now())
  activatedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  referralLinks     ReferralLink[]
  clients           Client[]
  transactions      PartnerTransaction[]
  commissionEntries CommissionEntry[]
  payouts           PartnerPayout[]
  agreements        PartnerAgreement[]
  clinicActivity    PartnerClinicActivity[]
  goals             PartnerGoal[]
  quotes            PartnerQuote[]

  @@unique([orgId, email])
  @@index([orgId])
}

// Invited org teammates (beyond the owner) with portal roles.
model PartnerOrgMember {
  id          String               @id @default(cuid())
  org         PartnerOrg           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  clerkUserId String?              @unique
  name        String
  email       String
  role        PartnerOrgMemberRole @default(VIEWER)
  status      PartnerStatus        @default(ACTIVE)
  invitedBy   String?
  invitedAt   DateTime             @default(now())
  activatedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([orgId, email])
  @@index([orgId])
}

// A shareable referral URL (/join/<code>). Deactivated links stop attributing
// immediately. Codes are unambiguous lowercase alphanumerics.
model ReferralLink {
  id          String      @id @default(cuid())
  code        String      @unique
  org         PartnerOrg  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  rep         PartnerRep? @relation(fields: [repId], references: [id], onDelete: Cascade)
  repId       String?
  label       String?
  active      Boolean     @default(true)
  clickCount  Int         @default(0)
  signupCount Int         @default(0)
  createdAt   DateTime    @default(now())
  clients     Client[]

  @@index([orgId])
}

// One attributed revenue event (usually a captured platform Order; also
// manual/CSV admin entries). org/rep are frozen at accrual time so later
// re-attribution never rewrites history. reference is unique for idempotency
// ("order:<orderId>" for platform orders).
model PartnerTransaction {
  id              String                   @id @default(cuid())
  client          Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String
  org             PartnerOrg               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId           String
  rep             PartnerRep?              @relation(fields: [repId], references: [id], onDelete: SetNull)
  repId           String?
  transactionDate DateTime
  description     String?
  reference       String?                  @unique
  revenueCents    Int
  // Wholesale cost (floor × qty) for MARGIN-model orgs; margin = revenue − cost.
  costCents       Int?
  refundedCents   Int                      @default(0)
  source          PartnerTransactionSource @default(ORDER)
  createdBy       String? // Clerk id (null for system accrual)
  createdAt       DateTime                 @default(now())
  entries         CommissionEntry[]

  @@index([clientId])
  @@index([orgId, transactionDate])
}

// Commission ledger. EARNING rows are written at accrual; REVERSAL rows claw
// back proportionally when the underlying transaction is refunded. Approve →
// pay lifecycle is admin-driven; a payout stamps payoutId and status PAID.
model CommissionEntry {
  id            String                @id @default(cuid())
  transaction   PartnerTransaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  transactionId String
  org           PartnerOrg            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId         String
  rep           PartnerRep?           @relation(fields: [repId], references: [id], onDelete: SetNull)
  repId         String?
  payee         CommissionPayee
  kind          CommissionEntryKind   @default(EARNING)
  rateBps       Int
  amountCents   Int // positive; REVERSAL rows subtract in rollups
  status        CommissionEntryStatus @default(PENDING)
  payout        PartnerPayout?        @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  payoutId      String?
  createdAt     DateTime              @default(now())

  @@index([orgId, status])
  @@index([repId])
  @@index([transactionId])
  @@index([payoutId])
}

// A recorded payment to an org or rep (check/ACH/wire — recorded, not moved).
model PartnerPayout {
  id              String            @id @default(cuid())
  org             PartnerOrg        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId           String
  rep             PartnerRep?       @relation(fields: [repId], references: [id], onDelete: SetNull)
  repId           String?
  payee           CommissionPayee
  amountCents     Int
  method          String?
  reference       String?
  notes           String?
  paidAt          DateTime          @default(now())
  recordedBy      String
  recordedByEmail String?
  createdAt       DateTime          @default(now())
  entries         CommissionEntry[]

  @@index([orgId])
}

// Per-variant wholesale floor for MARGIN-model orgs. The org may price its
// clinics at or above the floor; the spread is the org's margin.
model PartnerOrgPricing {
  id         String         @id @default(cuid())
  org        PartnerOrg     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId  String
  floorCents Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([orgId, variantId])
  @@index([orgId])
}

// Executed Marketing Services Agreement — the signed document of record.
model PartnerAgreement {
  id              String          @id @default(cuid())
  org             PartnerOrg      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId           String
  rep             PartnerRep?     @relation(fields: [repId], references: [id], onDelete: Cascade)
  repId           String?
  signerKind      CommissionPayee
  clerkUserId     String
  documentVersion String
  documentTitle   String
  documentHash    String
  documentText    String
  legalEntityName String?
  signerName      String
  signerTitle     String?
  signerEmail     String?
  signatureImage  String // data-URL PNG of the drawn/typed signature
  signedIp        String?
  signedUserAgent String?
  signedAt        DateTime        @default(now())
  createdAt       DateTime        @default(now())

  @@unique([orgId, repId, documentVersion])
  @@index([orgId])
  @@index([repId])
}

// Partner CRM: relationship stage + tags per (org, clinic).
model PartnerClinicMeta {
  id        String             @id @default(cuid())
  org       PartnerOrg         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  stage     PartnerClinicStage @default(ACTIVE)
  tags      Json               @default("[]")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([orgId, clientId])
  @@index([clientId])
}

// Partner CRM activity timeline (notes + logged stage/tag changes).
model PartnerClinicActivity {
  id        String                    @id @default(cuid())
  org       PartnerOrg                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId     String
  client    Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  rep       PartnerRep?               @relation(fields: [repId], references: [id], onDelete: SetNull)
  repId     String?
  actorKind CommissionPayee
  actorName String?
  type      PartnerClinicActivityType
  body      String
  createdAt DateTime                  @default(now())

  @@index([clientId, createdAt])
  @@index([orgId])
}

// Sales goals/quotas with progress tracked against the ledger.
model PartnerGoal {
  id          String            @id @default(cuid())
  org         PartnerOrg        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  rep         PartnerRep?       @relation(fields: [repId], references: [id], onDelete: Cascade)
  repId       String?
  metric      PartnerGoalMetric
  period      PartnerGoalPeriod
  targetCents Int
  createdBy   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([orgId, repId, metric, period])
  @@index([orgId])
}

// Partner-built price quote for a prospective/existing clinic. Items are a
// frozen snapshot: [{variantId, name, dose, quantity, unitPriceCents}].
model PartnerQuote {
  id          String             @id @default(cuid())
  org         PartnerOrg         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId       String
  rep         PartnerRep?        @relation(fields: [repId], references: [id], onDelete: SetNull)
  repId       String?
  clinicName  String
  contactName String?
  email       String?
  notes       String?
  items       Json               @default("[]")
  totalCents  Int                @default(0)
  status      PartnerQuoteStatus @default(DRAFT)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([orgId, createdAt])
}

// Read-only partner API keys. Only a SHA-256 hash is stored; the plaintext is
// shown once at creation. keyPrefix supports display + lookup.
model PartnerApiKey {
  id         String     @id @default(cuid())
  org        PartnerOrg @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId      String
  name       String
  keyPrefix  String
  keyHash    String     @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdBy  String?
  createdAt  DateTime   @default(now())

  @@index([orgId])
}

// Outbound webhook subscriptions (HMAC-signed deliveries, best-effort).
model PartnerWebhook {
  id             String     @id @default(cuid())
  org            PartnerOrg @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgId          String
  url            String
  secret         String
  events         Json       @default("[]")
  active         Boolean    @default(true)
  lastDeliveryAt DateTime?
  lastStatus     Int?
  createdBy      String?
  createdAt      DateTime   @default(now())

  @@index([orgId])
}

